# Orchestrator
SUPABASE_URL=                  # https://<project>.supabase.co (empty = in-memory dev store)
SUPABASE_SERVICE_KEY=          # service-role key — orchestrator only, never client-side
GRID_JOB_LEASE_SECONDS=300
GRID_JOB_MAX_ATTEMPTS=3
GRID_REQUEUE_INTERVAL=15
GRID_SETTLE_MINUTE=0
GRID_DISPATCH_TIMEOUT=300

# Provider daemon
GRID_WALLET_KEY=               # provider's wallet private key (BYOK — stays local)
