# Anthropic API Key for Claude-powered interview synthesis (claude-opus-4-8 by default).
# Without this, the app runs in local-first mock mode using the built-in 100-question bank.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Override the model used for synthesis (optional).
ANTHROPIC_MODEL=claude-opus-4-8

# Reddit API app credentials (free, "script" app type) for live forum scraping.
# Create one at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here

# GitHub personal access token (optional) — raises the code-search rate limit
# from 10/min (unauthenticated) to 30/min when hunting for company-tagged
# question repos.
GITHUB_TOKEN=your_github_token_here

# Set to "true" to force local-first mock mode even if API keys are present.
NEXT_PUBLIC_USE_MOCK_MODE=false
